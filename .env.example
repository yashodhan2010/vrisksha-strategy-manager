APP_NAME=Strategy Research Factory
APP_ENV=development
DATABASE_PATH=data/research_factory.db
LOG_DIR=logs

# Default profile used by profile-aware commands. Strategy identity, package
# metadata, optimization input, and export output paths live in this JSON file.
STRATEGY_PROFILE_PATH=strategies/dual-momentum/strategy_profile.json

MARKET_DATA_PROVIDER=KITE
DEFAULT_BENCHMARK_SYMBOL=NIFTY500
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8000/kite/callback
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=
KITE_ACCESS_TOKEN=
KITE_ACCESS_TOKEN_DATE=
KITE_EXCHANGE=NSE
KITE_BENCHMARK_TRADINGSYMBOL=NIFTY 500
KITE_HISTORICAL_DAY_CHUNK_DAYS=1900
KITE_REQUEST_SLEEP_SECONDS=0.4
KITE_MAX_RETRIES=5
KITE_RETRY_BACKOFF_SECONDS=2.0
SELENIUM_LOGIN_TIMEOUT_SECONDS=180

AUTO_REBALANCE_TARGET_DAYS=1,15
AUTOMATION_HISTORY_LOOKBACK_DAYS=10
MOMENTUM_SKIP_RECENT_DAYS=21
TARGET_PORTFOLIO_VALUE=1000000
AVAILABLE_PURCHASE_FUNDS=1000000
